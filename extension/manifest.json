{
  "manifest_version": 3,
  "name": "Pinboard Saver",
  "version": "0.1.0",
  "description": "Save the current tab to pinboard.in with one click.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.pinboard.in/*"],
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },
  "action": {
    "default_title": "Save to Pinboard",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
